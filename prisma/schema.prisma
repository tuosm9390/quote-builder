// prisma/schema.prisma
// Define your database models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Quotation {
  id          String    @id @default(uuid())
  title       String
  description String?
  
  // JSONB column storing the BlockNote blocks
  // e.g. [{ type: "header", data: ... }, { type: "pricingTable", data: ... }]
  blocks      Json      @default("[]") 
  
  // Total calculated amount for easy querying (Stored as Integer per FR-003)
  totalAmount Int       @default(0)

  // Status mapping: DRAFT, SENT, ACCEPTED, REJECTED
  status      String    @default("DRAFT")

  ownerId     String?   // FR-007: Owner-based access control
  deletedAt   DateTime? // FR-008: Soft Delete support

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
